{
  "name": "CRM para Supabase (simples)",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "crm-to-supabase",
        "responseMode": "lastNode",
        "options": {}
      },
      "id": "11111111-1111-1111-1111-111111111111",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [260, 300],
      "webhookId": "crm-to-supabase"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://yyhjubsbbbdhkuhchfqv.supabase.co/rest/v1/crm_events_log",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "YOUR_SUPABASE_SERVICE_ROLE_KEY" },
            { "name": "Authorization", "value": "Bearer YOUR_SUPABASE_SERVICE_ROLE_KEY" },
            { "name": "Content-Type", "value": "application/json" },
            { "name": "Prefer", "value": "return=minimal" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"event\": \"{{ $json.body.event || 'desconhecido' }}\",\n  \"tenant_id\": {{ $json.body.tenantId ? ('\"' + $json.body.tenantId + '\"') : 'null' }},\n  \"occurred_at\": \"{{ $json.body.occurredAt || $now }}\",\n  \"payload\": {{ JSON.stringify($json.body) }}\n}",
        "options": {}
      },
      "id": "22222222-2222-2222-2222-222222222222",
      "name": "Salvar no Supabase",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [560, 300]
    }
  ],
  "connections": {
    "Webhook": { "main": [[{ "node": "Salvar no Supabase", "type": "main", "index": 0 }]] }
  },
  "active": false,
  "settings": { "executionOrder": "v1" }
}
