        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "YOUR_SUPABASE_SERVICE_ROLE_KEY" },
            { "name": "Authorization", "value": "Bearer YOUR_SUPABASE_SERVICE_ROLE_KEY" },
            { "name": "Content-Type", "value": "application/json" },
            { "name": "Prefer", "value": "return=minimal" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"event\": \"{{$json.event}}\",\n  \"tenant_id\": {{ $json.tenantId ? ('\"' + $json.tenantId + '\"') : 'null' }},\n  \"delivery_id\": {{ $json.deliveryId ? ('\"' + $json.deliveryId + '\"') : 'null' }},\n  \"occurred_at\": \"{{$json.occurredAt}}\",\n  \"payload\": {{ JSON.stringify($json.raw) }}\n}",
        "options": {}
