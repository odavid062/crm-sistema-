        "jsCode": "// Achata o payload do CRM em campos faceis de usar.\nconst body = $json.body || {};\nreturn [{ json: {\n  event: body.event || 'desconhecido',\n  tenantId: body.tenantId || null,\n  occurredAt: body.occurredAt || new Date().toISOString(),\n  deliveryId: ($json.headers && $json.headers['x-crm-delivery']) || null,\n  data: body.data || {},\n  raw: body\n}}];"
      },
